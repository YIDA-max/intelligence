{
	"private": true,
	"name": "@ui-YIDA-erp",
	"version": "1.0.0",
	"description": "YIDA ERP",
	"author": "YIDA",
	"license": "MIT",
	"scripts": {
		"dev": "node ./scripts/dev.mjs",
		"all": "node ./scripts/run-all.mjs",
		"devAll": "node ./scripts/dev-multi.mjs",
		"ai": "node ./scripts/deepseek.mjs",
		"ai:review": "node ./scripts/deepseek.mjs --review",
		"deepseek:staged": "node ./scripts/deepseek-staged-review.mjs",
		"frontend:staged:review": "node ./scripts/frontend-staged-review/index.mjs --fail-on high",
		"java:staged:review": "node ./scripts/java-staged-review/index.mjs",
		"java:staged:review:block": "node ./scripts/java-staged-review/index.mjs --fail-on high",
		"preview": "node ./scripts/preview.mjs",
		"prebuild": "node scripts/generate-version.js",
		"build": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192 --max-semi-space-size=128\" node ./scripts/build.mjs",
		"buildLow": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096 --max-semi-space-size=128\" node ./scripts/build.mjs",
		"build:analyze": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192 --max-semi-space-size=128\" node ./scripts/build.mjs --mode analyze",
		"build:docker": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192 --max-semi-space-size=128\" node ./scripts/build.mjs --outDir ./docker/dist/",
		"version:generate": "node scripts/generate-version.js",
		"api:kingdee": "node scripts/generate-kingdee-api.mjs",
		"lint:eslint": "eslint --fix --ext .js,.ts,.vue ./src",
		"lint": "eslint src --ext .ts,.tsx && tsc --noEmit",
		"lint:fix": "eslint src --ext .ts,.tsx --fix",
		"lint:tsc": "tsc --noEmit --project tsconfig.lint.json",
		"lint:tsc-staged": "node scripts/lint-tsc-files.mjs",
		"lint:vue-tsc": "node scripts/lint-vue-tsc-files.mjs",
		"lint-staged": "lint-staged",
		"prettier": "prettier --write .",
		"p": "node ./scripts/prettier-unstaged.mjs",
		"prettier:watch": "node ./scripts/prettier-watch.mjs",
		"commit": "git add -A && git-cz",
		"analyzer": "vite-bundle-visualizer --open --gzip --brotli network",
		"delgit": "node scripts/delete-untracked-branches.js",
		"deploy": "node scripts/deploy.mjs"
	},
	"lint-staged": {
		"*.{ts,tsx}": [
			"eslint --fix",
			"prettier --write",
			"pnpm run lint:tsc-staged"
		],
		"*.vue": [
			"eslint --fix",
			"prettier --write",
			"pnpm run lint:vue-tsc"
		],
		"*.mjs": [
			"eslint --fix",
			"prettier --write"
		],
		"*.js": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,md}": [
			"prettier --write"
		]
	},
	"dependencies": {
		"@axolo/json-editor-vue": "^0.3.2",
