#!/usr/bin/env sh
PATH="/usr/local/bin:$PATH"

COMMIT_MSG=$(cat "$1")

if echo "$COMMIT_MSG" | grep -qE "^Merge (branch|pull request)"; then
  exit 0
fi

pnpm exec commitlint --edit "$1"
